# ─── Gemini AI API Key (required for AI features) ───────────────────────────
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Vite Base Path ─────────────────────────────────────────────────────────
# Use './' for cPanel/shared hosting (default)
# Use '/' for Netlify, Vercel, root domain
# Use '/your-repo-name/' for GitHub Pages subdirectory
VITE_BASE_PATH=./
